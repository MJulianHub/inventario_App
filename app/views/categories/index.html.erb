<h1>Categorias</h1>

<%= link_to "Nueva Categoria", new_category_path, class: "btn btn-primary" %>

<table>
  <thead>
    <tr>
      <th>Nombre</th>
      <th>Descripcion</th>
      <th>Productos</th>
      <th>Acciones</th>
    </tr>
  </thead>

  <tbody>
    <% @categories.each do |category| %>
      <tr>
        <td><%= category.name %></td>
        <td><%= category.description || "Sin descripcion" %></td>
        <td><%= category.products.count %></td>
        <td>
          <%= link_to "Ver", category, class: "btn btn-sm" %>
          <%= link_to "Editar", edit_category_path(category), class: "btn btn-sm" %>
          <%= link_to "Eliminar", category, class: "btn btn-sm btn-danger", data: { turbo_method: :delete, turbo_confirm: "Esta seguro de eliminar la categoria? Esto tambien eliminara todos los productos relacionados." } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
