<h1>Categories</h1>

<%= link_to "New Category", new_category_path %>

<ul>
  <% @categories.each do |category| %>
    <li>
      <%= category.name %>
      <%= link_to "Show", category %>
      <%= link_to "Edit", edit_category_path(category) %>
      <%= link_to "Delete", category, data: { turbo_method: :delete, turbo_confirm: "Esta seguro de eliminar la categoria" } %>
    </li>
  <% end %>
</ul>
