<h1>Movimientos de Stock</h1>

<%= link_to "Nuevo Movimiento", new_stock_path, class: "btn btn-primary btn-uniform" %>

<% if @stocks.any? %>
  <table>
    <thead>
      <tr>
        <th>Producto</th>
        <th>Tipo de Movimiento</th>
        <th>Cantidad</th>
        <th>Costo Unitario</th>
        <th>Fecha</th>
      </tr>
    </thead>

    <tbody>
      <% @stocks.each do |s| %>
        <tr>
          <td><%= s.product&.name %></td>
          <td>
            <%= case s.action
                when "addition" then "Entrada"
                when "removal" then "Salida"
                when "devolution" then "Devolucion"
                end %>
          </td>
          <td><%= s.quantity %></td>
          <td><%= number_to_currency(s.cost, unit: "C$", separator: ".", delimiter: ",") %></td>
          <td><%= s.created_at.strftime("%d/%m/%Y %I:%M %p") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="empty-message">No hay movimientos registrados. <%= link_to "Registrar primer movimiento", new_stock_path %></p>
<% end %>